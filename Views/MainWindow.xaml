<Window x:Class="SAV.MainWindow"
        Icon="/Assets/sav_icon.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAV"
        mc:Ignorable="d"
        Title="Sistema de Alterações de Vias">
    <Grid Background="{DynamicResource corDestaquePrimaria}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        
        <!-- Menu superior -->
        <Grid Grid.Row="0" Background="{DynamicResource corDestaquePrimaria}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Image Source="/Assets/sav_icon.png" Margin="12"/>
            </Grid>
            <Grid Grid.Column="1">
                <Rectangle Fill="{DynamicResource corTemaPrimaria}" Width="4" Height="50" />
            </Grid>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <TextBlock MouseDown="AbrirMapa_MouseDown" Grid.Column="0" Text="Abrir/Criar" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Style="{DynamicResource efeitoOpcoes}" Cursor="Hand"/>
                
                <TextBlock MouseDown="AbrirConfiguracoes_MouseDown" x:Name="abrirConfiguracoes" Grid.Column="1" Text="Configurações" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Style="{DynamicResource efeitoOpcoes}"/>

                <TextBlock Grid.Column="2" Text="Ajuda" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Style="{DynamicResource efeitoOpcoes}" Cursor="Hand"/>
            </Grid>
        </Grid>
        
        <!-- Conteúdo principal - mapa e menus laterais -->
        <Grid Grid.Row="1" Cursor="">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource corDestaqueTerciaria}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Editar -->
                <Grid Grid.Row="0">
                    <RadioButton x:Name="botaoEditar" 
                                 GroupName="Ferramentas"
                                 IsChecked="True"
                                 Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Grid Style="{DynamicResource fundoGridFerramentas}" Margin="0, 0, -10, 0">
                                    <Viewbox Width="30" Height="30">
                                        <Path Style="{DynamicResource efeitoEditar}"
                                              Data="M3.3572 3.23397C3.66645 2.97447 4.1014 
                                              2.92638 4.45988 3.11204L20.7851 11.567C21.1426 
                                              11.7522 21.3542 12.1337 21.322 12.5351C21.2898 
                                              12.9364 21.02 13.2793 20.6375 13.405L13.7827 
                                              15.6586L10.373 22.0179C10.1828 22.3728 9.79826 
                                              22.5789 9.39743 22.541C8.9966 22.503 8.65762 22.2284 
                                              8.53735 21.8441L3.04564 4.29872C2.92505 3.91345 3.04794 
                                              3.49346 3.3572 3.23397ZM5.67123 5.99173L9.73507 
                                              18.9752L12.2091 14.361C12.3304 14.1347 12.5341 13.9637 
                                              12.7781 13.8835L17.7518 12.2484L5.67123 5.99173Z"
                                              Stretch="Uniform">
                                        </Path>
                                    </Viewbox>
                                </Grid>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </Grid>

                <!-- Adicionar/criar -->
                <Grid Grid.Row="1">
                    <RadioButton x:Name="botaoAdicionar" 
                                 GroupName="Ferramentas" 
                                 Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Grid Style="{DynamicResource fundoGridFerramentas}" Margin="0, 0, -10, 0">
                                    <Viewbox Width="30" Height="30">
                                        <Path Style="{DynamicResource efeitoAdicionar}"
                                              Data="M4 12H20M12 4V20"
                                              StrokeThickness="2" 
                                              Stretch="Uniform">
                                        </Path>
                                    </Viewbox>
                                </Grid>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </Grid>

                <!-- Deletar -->
                <Grid Grid.Row="2">
                    <RadioButton x:Name="botaoDeletar" 
                                 GroupName="Ferramentas" 
                                 Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Grid Style="{DynamicResource fundoGridFerramentas}" Margin="0, 0, -10, 0">
                                    <Viewbox Width="30" Height="30" Cursor="">
                                        <Path Style="{DynamicResource efeitoDeletar}"
                                              Data="M5.29289 5.29289C5.68342 4.90237 
                                              6.31658 4.90237 6.70711 5.29289L12 
                                              10.5858L17.2929 5.29289C17.6834 4.90237 
                                              18.3166 4.90237 18.7071 5.29289C19.0976 
                                              5.68342 19.0976 6.31658 18.7071
                                              6.70711L13.4142 12L18.7071 17.2929C19.0976
                                              17.6834 19.0976 18.3166 18.7071 18.7071C18.3166
                                              19.0976 17.6834 19.0976 17.2929 18.7071L12
                                              13.4142L6.70711 18.7071C6.31658 19.0976 5.68342
                                              19.0976 5.29289 18.7071C4.90237 18.3166 4.90237
                                              17.6834 5.29289 17.2929L10.5858 12L5.29289
                                              6.70711C4.90237 6.31658 4.90237 5.68342
                                              5.29289 5.29289Z" 
                                              Stretch="Uniform" Cursor="Hand">
                                        </Path>
                                    </Viewbox>
                                </Grid>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding MinhasVias}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Background="Transparent" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Polyline Points="{Binding Pontos}" Stroke="{DynamicResource corTemaPrimaria}" StrokeThickness="4" 
                              Cursor="Hand" MouseDown="Via_MouseDown" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Grid Grid.Column="2" Background="{DynamicResource corDestaqueTerciaria}">
                
            </Grid>
        </Grid>

        <!-- Menu inferior-->
        <Grid Grid.Row="2" Background="{DynamicResource corDestaquePrimaria}">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
            </Grid>

            <Grid Grid.Row="1">
                <Grid Background="{DynamicResource corDestaqueTerciaria}" Margin="8">
                    
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
