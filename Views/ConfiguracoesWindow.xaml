<Window x:Class="SAV.Views.ConfiguracoesWindow"
        Icon="/Assets/sav_icon.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAV.Views"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="Configurações" Height="450" Width="400" >
    <Grid Background="{DynamicResource corDestaquePrimaria}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Label Content="Tema" FontSize="16"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Foreground="{DynamicResource corFonte}" />
            <ToggleButton x:Name="trocarTema" 
                          Content="Claro"
                          Style="{DynamicResource corBotaoTema}" 
                          Cursor="Hand" BorderThickness="0" 
                          Width="120" Height="20"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Checked="trocarTema_Checked"
                          Unchecked="trocarTema_Unchecked" FontSize="12" 
                          Foreground="{DynamicResource corFonte}" 
                          FontFamily="{DynamicResource fontePadrao}" />
        </Grid>

        <Grid Grid.Row="1" Margin="10">
            <Label Content="Salvamento automático" FontSize="16"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Foreground="{DynamicResource corFonte}"/>
            <Button x:Name="botaoSalvamento"
                    Content="Selecionar caminho"
                    Click="botaoSalvamentoAutomatico_Click"
                    Style="{DynamicResource botoesPadrao}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" Cursor="Hand">
                <Button.ContextMenu>
                    <ContextMenu x:Name="MenuOpcoes">
                        <MenuItem Header="5 minutos" Tag="5" Click="opcaoSalvamentoAutomatico_Click"/>
                        <MenuItem Header="10 minutos" Tag="10" Click="opcaoSalvamentoAutomatico_Click"/>
                        <MenuItem Header="15 minutos" Tag="15" Click="opcaoSalvamentoAutomatico_Click"/>
                        <MenuItem Header="30 minutos" Tag="30" Click="opcaoSalvamentoAutomatico_Click"/>
                        <Separator />
                        <MenuItem Header="Nunca" Tag="Nunca" Click="opcaoSalvamentoAutomatico_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Label Content="Diretório padrão:" FontSize="16"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource corFonte}" />
                <Button x:Name="botaoCaminho"
                        Content="Selecionar caminho"
                        Click="botaoCaminho_Click"
                        Style="{DynamicResource botoesPadrao}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
            </Grid>
            <Grid Grid.Row="1" Background="{DynamicResource corDestaqueTerciaria}">
                <TextBlock x:Name="textoDiretorio" 
                         Margin="5, 0" 
                         Text="C:/"
                         VerticalAlignment="Center"
                         Background="Transparent"
                         FontFamily="{StaticResource fontePadrao}"
                         Foreground="{DynamicResource corFonte}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
