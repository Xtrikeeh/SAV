<Window x:Class="SAV.Views.ConfiguracoesWindow"
        Icon="/Assets/sav_icon.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAV.Views"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="Configurações" Height="450" Width="400" >
    <Grid Background="{DynamicResource corDestaquePrimaria}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <!-- Tema -->
        <Grid Grid.Row="0" Margin="10">
            <Label Content="Tema" FontSize="16"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Foreground="{DynamicResource corFonte}" />
            <Button x:Name="botaoTrocarTema"
                    Content="{Binding TemaEscolhido}"
                    Style="{DynamicResource botaoPadrao}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="BotaoTrocarTema_Click" />
        </Grid>

        <!-- Salvamento automático -->
        <Grid Grid.Row="1" Margin="10">
            <Label Content="Salvamento automático" FontSize="16"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Foreground="{DynamicResource corFonte}"/>
            <Button Content="{Binding SalvamentoAutomaticoEscolhido}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{DynamicResource botaoPadrao}"
                    Click="BotaoSalvamentoAutomatico_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="MenuOpcoes">
                        <MenuItem Header="5 minutos" Tag="5" Click="OpcaoSalvamento_Click" />
                        <MenuItem Header="10 minutos" Tag="10" Click="OpcaoSalvamento_Click" />
                        <MenuItem Header="15 minutos" Tag="15" Click="OpcaoSalvamento_Click" />
                        <MenuItem Header="30 minutos" Tag="30" Click="OpcaoSalvamento_Click" />
                        <Separator />
                        <MenuItem Header="Nunca" Tag="Nunca" Click="OpcaoSalvamento_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Diretório padrão -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Label Content="Diretório padrão:" FontSize="16"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource corFonte}" />
                <Button Content="Selecionar caminho"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{DynamicResource botaoPadrao}"
                        Click="BotaoEscolherDiretorio_Click" Cursor="" />
            </Grid>
            <Grid Grid.Row="1" Background="{DynamicResource corDestaqueTerciaria}">
                <TextBlock x:Name="textoDiretorio" 
                         Margin="5, 0" 
                         Text="{Binding DiretorioPadrao}"
                         VerticalAlignment="Center"
                         Background="Transparent"
                         FontFamily="{StaticResource fontePadrao}"
                         Foreground="{DynamicResource corFonte}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
